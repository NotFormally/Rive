# Rive — Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Anthropic AI (Required for IA features: Instagram, Menu Engineering, Logbook)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (Optional fallback)
OPENAI_API_KEY=

# Resend (Required for transactional emails)
RESEND_API_KEY=re_...

# Cron Job Security (Required — set any random secret string)
CRON_SECRET=your_random_secret_here

# Supabase Service Role (Required for cron + email lookups)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site URL (Required for SEO: sitemap, canonical URLs, Open Graph)
NEXT_PUBLIC_SITE_URL=https://rive.vercel.app

# Stripe (Required for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Cloudflare Turnstile (Required for bot protection on signup/login)
# Get keys from: https://dash.cloudflare.com → Turnstile → Add Site
# Test keys (always pass): Site=1x00000000000000000000AA, Secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Google Places API (Required for Le Baromètre weather + visibility score)
GOOGLE_PLACES_API_KEY=

# Social Media OAuth (Optional — for Social Hub)
META_APP_ID=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# POS Integrations (Optional — per integration)
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
SQUARE_ACCESS_TOKEN=
LIGHTSPEED_API_KEY=
SUMUP_API_KEY=
ZETTLE_API_KEY=
