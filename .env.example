# Rive — Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Anthropic AI (Required for IA features: Instagram, Menu Engineering, Logbook)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (Optional fallback)
OPENAI_API_KEY=

# Resend (Required for transactional emails)
RESEND_API_KEY=re_...

# Cron Job Security (Required — set any random secret string)
CRON_SECRET=your_random_secret_here

# Supabase Service Role (Required for cron + email lookups)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site URL (Required for SEO: sitemap, canonical URLs, Open Graph)
NEXT_PUBLIC_SITE_URL=https://rive.vercel.app

# Stripe (Required for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Social Media OAuth (Optional — for Social Hub)
META_APP_ID=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# POS Integrations (Optional — per integration)
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
SQUARE_ACCESS_TOKEN=
LIGHTSPEED_API_KEY=
SUMUP_API_KEY=
ZETTLE_API_KEY=
